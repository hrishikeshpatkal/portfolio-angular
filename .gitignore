# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Dependencies
/node_modules/

# Angular / TypeScript build output
/dist/
/tmp/
/out-tsc/
/bazel-out/
/.angular/cache/

# Test and coverage output
/coverage/
/.nyc_output/
/test-results/
/playwright-report/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables and local secrets
.env
.env.*
!.env.example
!.env.*.example

# Package manager caches
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Cursor local state
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Miscellaneous
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

